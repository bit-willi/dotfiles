#!/usr/bin/env bash

# --- Configuration ---
STATE_FILE="$HOME/.cache/pomodoro.json"
ICON_WORK="🍅"
ICON_BREAK="☕"
ICON_OFF="🌙"
ICON_PAUSED="⏸️"

# Your Custom Schedule (HH:MM-HH:MM)
SCHEDULE=(
    "08:00-09:30"
    "09:50-11:20"
    "12:00-12:30"
    "13:50-15:20"
    "15:40-17:10"
    "17:30-19:00"
    "19:20-20:00"
)

# Ensure state file exists
if [[ ! -f "$STATE_FILE" ]]; then echo '{"paused": false}' > "$STATE_FILE"; fi

# --- Actions ---
case "$1" in
    toggle-pause)
        is_paused=$(jq -r '.paused' "$STATE_FILE")
        if [[ "$is_paused" == "true" ]]; then
            echo '{"paused": false}' > "$STATE_FILE"
            notify-send -a "Pomodoro" "Resumed" "Following schedule..."
        else
            echo '{"paused": true}' > "$STATE_FILE"
            pactl set-sink-mute @DEFAULT_SINK@ 0
            dunstctl set-paused false
            notify-send -a "Pomodoro" "Paused" "DND disabled until un-paused."
        fi
        exit 0
        ;;
esac

# --- Logic ---
NOW=$(date +%s)
IS_PAUSED=$(jq -r '.paused' "$STATE_FILE")
CURRENT_MODE="OFF"
REMAINING=0
CLASS="off"
ICON=$ICON_OFF

# Find where we are in the schedule
for slot in "${SCHEDULE[@]}"; do
    START_STR=$(echo $slot | cut -d'-' -f1)
    END_STR=$(echo $slot | cut -d'-' -f2)
    START_TS=$(date -d "$START_STR" +%s)
    END_TS=$(date -d "$END_STR" +%s)

    if [[ "$NOW" -ge "$START_TS" && "$NOW" -lt "$END_TS" ]]; then
        CURRENT_MODE="WORK"
        REMAINING=$(( END_TS - NOW ))
        ICON=$ICON_WORK
        CLASS="work"
        break
    elif [[ "$NOW" -lt "$START_TS" ]]; then
        CURRENT_MODE="BREAK"
        REMAINING=$(( START_TS - NOW ))
        ICON=$ICON_BREAK
        CLASS="break"
        break
    fi
done

# Handle DND and Output
if [[ "$IS_PAUSED" == "true" ]]; then
    # When paused, we ignore the DND rules but keep showing the timer
    ICON=$ICON_PAUSED
    CLASS="paused"
    pactl set-sink-mute @DEFAULT_SINK@ 0
    dunstctl set-paused false
else
    # Apply DND based on mode
    if [[ "$CURRENT_MODE" == "WORK" ]]; then
        pactl set-sink-mute @DEFAULT_SINK@ 1
        dunstctl set-paused true
    else
        pactl set-sink-mute @DEFAULT_SINK@ 0
        dunstctl set-paused false
    fi
fi

# Format output
if [[ "$REMAINING" -le 0 ]]; then
    TEXT="Done $ICON_OFF"
else
    MINS=$(( REMAINING / 60 ))
    SECS=$(( REMAINING % 60 ))
    TIME_STR=$(printf "%02d:%02d" $MINS $SECS)
    TEXT="$ICON $TIME_STR"
fi

jq -n -c \
  --arg text "$TEXT" \
  --arg tooltip "Status: $CURRENT_MODE (Paused: $IS_PAUSED)" \
  --arg class "$CLASS" \
  '{"text": $text, "tooltip": $tooltip, "class": $class}'
