#!/usr/bin/env bash

# --- Configuration ---
STATE_FILE="$HOME/.cache/pomodoro.json"
ICON_WORK="🍅"
ICON_BREAK="☕"
ICON_OFF="🌙"
ICON_PAUSED="⏸️"

# Your Custom Schedule (HH:MM-HH:MM)
SCHEDULE=(
    "08:00-09:30"
    "09:50-11:20"
    "12:00-13:30"
    "13:50-15:20"
    "15:40-17:10"
    "17:30-19:00"
    "19:20-20:00"
)

# Ensure state file exists
if [[ ! -f "$STATE_FILE" ]]; then echo '{"paused": false, "last_mode": "OFF"}' > "$STATE_FILE"; fi

# --- Actions ---
case "$1" in
    toggle-pause)
        is_paused=$(jq -r '.paused' "$STATE_FILE")
        if [[ "$is_paused" == "true" ]]; then
            jq '.paused = false' "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
            notify-send -a "Pomodoro" "Resumed" "Following schedule..."
        else
            jq '.paused = true' "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
            pactl set-sink-mute @DEFAULT_SINK@ 0
            dunstctl set-paused false
            notify-send -a "Pomodoro" "Paused" "DND disabled until un-paused."
        fi
        exit 0
        ;;
    restart)
        echo '{"paused": false, "last_mode": "OFF"}' > "$STATE_FILE"
        notify-send -a "Pomodoro" "Restarted" "State reset. Following schedule..."
        exit 0
        ;;
    skip)
        current_mode=$(jq -r '.last_mode // "OFF"' "$STATE_FILE")
        jq --arg mode "$current_mode" '.last_mode = $mode' "$STATE_FILE" > "$STATE_FILE.tmp" && mv "$STATE_FILE.tmp" "$STATE_FILE"
        notify-send -a "Pomodoro" "Skipped" "Advancing to next slot..."
        exit 0
        ;;
esac

# --- Logic ---
NOW=$(date +%s)
IS_PAUSED=$(jq -r '.paused' "$STATE_FILE")
CURRENT_MODE="OFF"
REMAINING=0
CLASS="off"
ICON=$ICON_OFF

# Find where we are in the schedule
for slot in "${SCHEDULE[@]}"; do
    START_STR=$(echo $slot | cut -d'-' -f1)
    END_STR=$(echo $slot | cut -d'-' -f2)
    START_TS=$(date -d "$START_STR" +%s)
    END_TS=$(date -d "$END_STR" +%s)

    if [[ "$NOW" -ge "$START_TS" && "$NOW" -lt "$END_TS" ]]; then
        CURRENT_MODE="WORK"
        REMAINING=$(( END_TS - NOW ))
        ICON=$ICON_WORK
        CLASS="work"
        break
    elif [[ "$NOW" -lt "$START_TS" ]]; then
        CURRENT_MODE="BREAK"
        REMAINING=$(( START_TS - NOW ))
        ICON=$ICON_BREAK
        CLASS="break"
        break
    fi
done

# Track mode transitions (only act on change, not every tick)
LAST_MODE=$(jq -r '.last_mode // "OFF"' "$STATE_FILE")

# Handle DND and Output
if [[ "$IS_PAUSED" == "true" ]]; then
    # When paused, we ignore the DND rules but keep showing the timer
    ICON=$ICON_PAUSED
    CLASS="paused"
    # Don't touch audio/notifications — user has full control
else
    if [[ "$CURRENT_MODE" == "WORK" ]]; then
        # During work: enforce DND every tick (always muted)
        pactl set-sink-mute @DEFAULT_SINK@ 1
        dunstctl set-paused true
    elif [[ "$LAST_MODE" == "WORK" && "$CURRENT_MODE" != "WORK" ]]; then
        # Transition WORK→BREAK/OFF: unmute once, then hands off
        pactl set-sink-mute @DEFAULT_SINK@ 0
        dunstctl set-paused false
    fi
    # During BREAK/OFF (not transitioning): don't touch mute — user controls it
fi

# Persist current mode for transition detection (atomic write to avoid race condition)
jq -c --arg last_mode "$CURRENT_MODE" '.last_mode = $last_mode' "$STATE_FILE" > "$STATE_FILE.tmp" \
  && mv "$STATE_FILE.tmp" "$STATE_FILE"

# Format output
if [[ "$REMAINING" -le 0 ]]; then
    TEXT="Done $ICON_OFF"
else
    MINS=$(( REMAINING / 60 ))
    SECS=$(( REMAINING % 60 ))
    TIME_STR=$(printf "%02d:%02d" $MINS $SECS)
    TEXT="$ICON $TIME_STR"
fi

jq -n -c \
  --arg text "$TEXT" \
  --arg tooltip "Status: $CURRENT_MODE (Paused: $IS_PAUSED)" \
  --arg class "$CLASS" \
  '{"text": $text, "tooltip": $tooltip, "class": $class}'
